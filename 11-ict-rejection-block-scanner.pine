// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0
// https://mozilla.org/MPL/2.0/
// © EmpArchitect
// ICT Rejection Block Scanner — detects and grades rejection candles at key levels
// A rejection block is a candle with a long wick that rejects from a level and closes
// back inside the previous range. The wick shows where orders were absorbed.
// No entries, no SL/TP — rejection analysis only.
// v1.0

//@version=6
indicator("ICT Rejection Block Scanner [EmpArchitect]", overlay=true,
     max_boxes_count=200, max_labels_count=100)

// ═══════════════════════════════════════════════════════════════════════
//  INPUTS
// ═══════════════════════════════════════════════════════════════════════

grpDetect  = "═══ Detection ═══"
i_wickRatio = input.float(1.5, "Min Wick:Body Ratio", minval=1.0, maxval=5.0, step=0.5, group=grpDetect,
     tooltip="Minimum ratio of rejection wick to candle body. Higher = stricter. 2.0 = wick must be 2× the body size.")
i_wickPct  = input.float(0.4, "Min Wick % of Range", minval=0.3, maxval=0.9, step=0.1, group=grpDetect,
     tooltip="Rejection wick must be at least this % of total candle range. 0.6 = wick is 60%+ of the candle.")
i_atrMult  = input.float(0.5, "Min Candle Size (× ATR)", minval=0.1, maxval=2.0, step=0.1, group=grpDetect,
     tooltip="Minimum total candle range as multiple of ATR. Filters out tiny insignificant rejections.")
i_atrLen   = input.int(14, "ATR Length", minval=5, maxval=50, group=grpDetect)
i_volConf  = input.bool(true, "Volume Confirmation", group=grpDetect,
     tooltip="Require above-average volume on rejection candle for higher confidence.")
i_volMult  = input.float(1.2, "Volume Multiplier", minval=1.0, maxval=3.0, step=0.1, group=grpDetect)

grpZone    = "═══ Zones ═══"
i_maxZones = input.int(15, "Max Active Zones", minval=5, maxval=30, group=grpZone)
i_maxAge   = input.int(150, "Max Age (bars)", minval=20, maxval=500, group=grpZone)
i_showMit  = input.bool(true, "Show Mitigated Zones", group=grpZone,
     tooltip="Keep mitigated zones visible but faded.")
i_mitType  = input.string("Wick", "Mitigation Type", options=["Wick", "Close"], group=grpZone)

grpGrade   = "═══ Grading ═══"
i_showGrade = input.bool(true, "Show Grade Labels", group=grpGrade,
     tooltip="Grade each rejection: A (strongest), B (good), C (weak)")

grpVis     = "═══ Visual ═══"
i_bullCl   = input.color(#14B8A6, "Bullish Rejection (Teal)", group=grpVis)
i_bearCl   = input.color(#F59E0B, "Bearish Rejection (Amber)", group=grpVis)
i_textCl   = input.color(#F8FAFC, "Text", group=grpVis)

grpDash    = "═══ Dashboard ═══"
i_showDash = input.bool(true, "Show Dashboard", group=grpDash)
i_dashPos  = input.string("Top Right", "Position",
     options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=grpDash)

// ═══════════════════════════════════════════════════════════════════════
//  ATR & VOLUME
// ═══════════════════════════════════════════════════════════════════════

float atrVal = ta.atr(i_atrLen)
float vol20  = ta.sma(volume, 20)

// ═══════════════════════════════════════════════════════════════════════
//  REJECTION DETECTION — on closed bar (bar[1])
// ═══════════════════════════════════════════════════════════════════════

float o1 = open[1]
float h1 = high[1]
float l1 = low[1]
float c1 = close[1]
float v1 = volume[1]

float body1      = math.abs(c1 - o1)
float candleRng  = h1 - l1
float upperWick1 = h1 - math.max(o1, c1)
float lowerWick1 = math.min(o1, c1) - l1

// Prevent division by zero
float safeBody  = math.max(body1, candleRng * 0.001)
float safeRng   = math.max(candleRng, atrVal * 0.01)

// Bullish rejection: long lower wick, closes in upper portion
bool bullRejection = lowerWick1 / safeBody >= i_wickRatio and
     lowerWick1 / safeRng >= i_wickPct and
     candleRng >= atrVal * i_atrMult and
     c1 > o1

// Bearish rejection: long upper wick, closes in lower portion
bool bearRejection = upperWick1 / safeBody >= i_wickRatio and
     upperWick1 / safeRng >= i_wickPct and
     candleRng >= atrVal * i_atrMult and
     c1 < o1

// Volume confirmation
bool volOk = not i_volConf or v1 >= vol20 * i_volMult

// ═══════════════════════════════════════════════════════════════════════
//  GRADING
// ═══════════════════════════════════════════════════════════════════════

f_grade(float wick, float body, float rng, float vol, float avgVol, float atr) =>
    int score = 0
    // Wick dominance
    float wickRat = wick / math.max(body, rng * 0.001)
    if wickRat >= 4.0
        score += 3
    else if wickRat >= 3.0
        score += 2
    else
        score += 1
    // Wick % of candle
    float wickP = wick / math.max(rng, atr * 0.01)
    if wickP >= 0.75
        score += 2
    else if wickP >= 0.65
        score += 1
    // Volume
    if vol >= avgVol * 2.0
        score += 2
    else if vol >= avgVol * 1.5
        score += 1
    // Candle size
    if rng >= atr * 1.0
        score += 1
    // Grade
    string grade = score >= 6 ? "A" : score >= 4 ? "B" : "C"
    grade

// ═══════════════════════════════════════════════════════════════════════
//  ZONE MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════

var array<float> zTop       = array.new<float>()
var array<float> zBot       = array.new<float>()
var array<int>   zBar       = array.new<int>()
var array<bool>  zIsBull    = array.new<bool>()
var array<bool>  zMitigated = array.new<bool>()
var array<string> zGrade    = array.new<string>()
var array<box>   zBox       = array.new<box>()
var array<label> zLabel     = array.new<label>()

// Stats
var int totalBullRej  = 0
var int totalBearRej  = 0
var int mitBullCount  = 0
var int mitBearCount  = 0
var int gradeAcount   = 0
var int gradeBcount   = 0
var int gradeCcount   = 0

// Add bullish rejection zone
if bullRejection and volOk
    float top = math.min(o1, c1)
    float bot = l1
    string grade = f_grade(lowerWick1, body1, candleRng, v1, vol20, atrVal)

    color zoneCol = i_bullCl
    int alpha = grade == "A" ? 70 : grade == "B" ? 78 : 84

    box b = box.new(bar_index - 1, top, bar_index + 5, bot,
         border_color=color.new(zoneCol, alpha - 20), bgcolor=color.new(zoneCol, alpha),
         border_width=1)

    label lb = na
    if i_showGrade
        lb := label.new(bar_index - 1, bot, grade,
             style=label.style_label_up, color=color.new(zoneCol, 70),
             textcolor=zoneCol, size=size.tiny)

    zTop.push(top)
    zBot.push(bot)
    zBar.push(bar_index)
    zIsBull.push(true)
    zMitigated.push(false)
    zGrade.push(grade)
    zBox.push(b)
    zLabel.push(lb)
    totalBullRej += 1
    if grade == "A"
        gradeAcount += 1
    else if grade == "B"
        gradeBcount += 1
    else
        gradeCcount += 1

// Add bearish rejection zone
if bearRejection and volOk
    float top = h1
    float bot = math.max(o1, c1)
    string grade = f_grade(upperWick1, body1, candleRng, v1, vol20, atrVal)

    color zoneCol = i_bearCl
    int alpha = grade == "A" ? 70 : grade == "B" ? 78 : 84

    box b = box.new(bar_index - 1, top, bar_index + 5, bot,
         border_color=color.new(zoneCol, alpha - 20), bgcolor=color.new(zoneCol, alpha),
         border_width=1)

    label lb = na
    if i_showGrade
        lb := label.new(bar_index - 1, top, grade,
             style=label.style_label_down, color=color.new(zoneCol, 70),
             textcolor=zoneCol, size=size.tiny)

    zTop.push(top)
    zBot.push(bot)
    zBar.push(bar_index)
    zIsBull.push(false)
    zMitigated.push(false)
    zGrade.push(grade)
    zBox.push(b)
    zLabel.push(lb)
    totalBearRej += 1
    if grade == "A"
        gradeAcount += 1
    else if grade == "B"
        gradeBcount += 1
    else
        gradeCcount += 1

// ═══════════════════════════════════════════════════════════════════════
//  UPDATE ZONES — extend, mitigate, cleanup
// ═══════════════════════════════════════════════════════════════════════

if zTop.size() > 0
    int i = zTop.size() - 1
    while i >= 0
        float top    = zTop.get(i)
        float bot    = zBot.get(i)
        int   formBar = zBar.get(i)
        bool  isBull = zIsBull.get(i)
        bool  mit    = zMitigated.get(i)
        box   b      = zBox.get(i)

        int age = bar_index - formBar

        // Remove old zones
        if age > i_maxAge
            box.delete(b)
            label lbDel = zLabel.get(i)
            if not na(lbDel)
                label.delete(lbDel)
            zTop.remove(i)
            zBot.remove(i)
            zBar.remove(i)
            zIsBull.remove(i)
            zMitigated.remove(i)
            zGrade.remove(i)
            zBox.remove(i)
            zLabel.remove(i)
            i -= 1
            continue

        // Check mitigation
        if not mit
            bool nowMit = false
            if i_mitType == "Wick"
                if isBull and low < bot
                    nowMit := true
                if not isBull and high > top
                    nowMit := true
            else
                if isBull and close < bot
                    nowMit := true
                if not isBull and close > top
                    nowMit := true

            if nowMit
                zMitigated.set(i, true)
                if isBull
                    mitBullCount += 1
                else
                    mitBearCount += 1

                color fadeCol = isBull ? i_bullCl : i_bearCl
                box.set_bgcolor(b, color.new(fadeCol, 92))
                box.set_border_color(b, color.new(fadeCol, 88))
                box.set_border_style(b, line.style_dotted)

                if not i_showMit
                    box.delete(b)
                    label lbMit = zLabel.get(i)
                    if not na(lbMit)
                        label.delete(lbMit)

            // Extend active zones
            if not nowMit
                box.set_right(b, bar_index + 3)

        i -= 1

// Trim to max zones
while zTop.size() > i_maxZones
    box.delete(zBox.get(0))
    label lb0 = zLabel.get(0)
    if not na(lb0)
        label.delete(lb0)
    zTop.shift()
    zBot.shift()
    zBar.shift()
    zIsBull.shift()
    zMitigated.shift()
    zGrade.shift()
    zBox.shift()
    zLabel.shift()

// ═══════════════════════════════════════════════════════════════════════
//  STATISTICS
// ═══════════════════════════════════════════════════════════════════════

int totalRej     = totalBullRej + totalBearRej
int totalMit     = mitBullCount + mitBearCount
float mitRate    = totalRej > 0 ? (totalMit * 100.0 / totalRej) : 0.0
float gradeAPct  = totalRej > 0 ? (gradeAcount * 100.0 / totalRej) : 0.0

int activeZones = 0
if zMitigated.size() > 0
    for j = 0 to zMitigated.size() - 1
        if not zMitigated.get(j)
            activeZones += 1

// ═══════════════════════════════════════════════════════════════════════
//  DASHBOARD
// ═══════════════════════════════════════════════════════════════════════

var string dPos = i_dashPos == "Top Right" ? position.top_right : i_dashPos == "Top Left" ? position.top_left : i_dashPos == "Bottom Right" ? position.bottom_right : position.bottom_left

var table dash = table.new(dPos, 4, 5,
     bgcolor=color.new(color.black, 82), border_width=0)

if barstate.islast and i_showDash
    // Header
    table.cell(dash, 0, 0, "Rejection Blocks", text_color=i_textCl, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 0, "", text_size=size.tiny)
    table.cell(dash, 2, 0, str.tostring(activeZones) + " active", text_color=activeZones > 3 ? i_bullCl : color.gray, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 3, 0, "[EmpArchitect]", text_color=i_bullCl, text_size=size.tiny, text_halign=text.align_right)

    // Stats
    table.cell(dash, 0, 1, "▲ Bull", text_color=i_bullCl, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 1, str.tostring(totalBullRej), text_color=i_textCl, text_size=size.tiny, text_halign=text.align_center)
    table.cell(dash, 2, 1, "▼ Bear", text_color=i_bearCl, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 3, 1, str.tostring(totalBearRej), text_color=i_textCl, text_size=size.tiny, text_halign=text.align_center)

    // Grades
    table.cell(dash, 0, 2, "Grades", text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 2, "A:" + str.tostring(gradeAcount), text_color=i_bullCl, text_size=size.tiny, text_halign=text.align_center)
    table.cell(dash, 2, 2, "B:" + str.tostring(gradeBcount), text_color=i_bearCl, text_size=size.tiny, text_halign=text.align_center)
    table.cell(dash, 3, 2, "C:" + str.tostring(gradeCcount), text_color=color.gray, text_size=size.tiny, text_halign=text.align_center)

    // Mitigation
    table.cell(dash, 0, 3, "Mitigated", text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 3, str.tostring(totalMit) + "/" + str.tostring(totalRej), text_color=i_textCl, text_size=size.tiny, text_halign=text.align_center)
    table.cell(dash, 2, 3, str.tostring(mitRate, "#.0") + "%", text_color=mitRate > 50 ? i_bearCl : i_bullCl, text_size=size.tiny, text_halign=text.align_center)
    table.cell(dash, 3, 3, "", text_size=size.tiny)

    // Grade A %
    table.cell(dash, 0, 4, "A-Grade %", text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 4, str.tostring(gradeAPct, "#.0") + "%", text_color=gradeAPct > 20 ? i_bullCl : color.gray, text_size=size.tiny, text_halign=text.align_center)
    table.cell(dash, 2, 4, "", text_size=size.tiny)
    table.cell(dash, 3, 4, "Wick:" + str.tostring(i_wickRatio, "#.0") + "× Body", text_color=color.gray, text_size=size.tiny, text_halign=text.align_right)

// ═══════════════════════════════════════════════════════════════════════
//  ALERTS
// ═══════════════════════════════════════════════════════════════════════

alertcondition(bullRejection and volOk, "Bullish Rejection Block", "Bullish rejection block detected — long wick absorbed selling pressure")
alertcondition(bearRejection and volOk, "Bearish Rejection Block", "Bearish rejection block detected — long wick absorbed buying pressure")